{
  "Persistence": {
    "Provider": "Sqlite"
  },
  "ConnectionStrings": {
    "Sqlite": "Data Source=../../../../App_Data/cvanalysishub.shared.db",
    "PostgreSql": "Host=localhost;Port=5432;Database=cvanalysishub;Username=postgres;Password=postgres"
  },
  "MediaStorage": {
    "RootPath": "../../../../App_Data/media"
  },
  "VideoProcessing": {
    "FfmpegPath": "/usr/bin/ffmpeg"
  },
  "ComputerVision": {
    "Provider": "YoloDotNet",
    "YoloDotNet": {
      "ModelPath": "../../../../App_Data/models/yolov8n.onnx",
      "ConfidenceThreshold": 0.25,
      "IouThreshold": 0.7,
      "FrameSampleIntervalSeconds": 1,
      "MaxFramesPerRun": 120
    }
  }
}
