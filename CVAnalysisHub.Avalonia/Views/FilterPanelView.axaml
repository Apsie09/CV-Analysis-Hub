<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:filters="using:CVAnalysisHub.Application.Common.Filters"
             x:Class="CVAnalysisHub.Avalonia.Views.FilterPanelView"
             x:Name="Root">
    <Expander IsExpanded="False">
        <Expander.Header>
            <StackPanel Spacing="4">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Advanced filters" />
                <TextBlock Foreground="#52606D"
                           Text="Controls are generated from the shared filter metadata." />
            </StackPanel>
        </Expander.Header>

        <StackPanel Margin="0,16,0,0" Spacing="14">
            <ItemsControl ItemsSource="{Binding #Root.Fields}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="filters:FilterFieldViewModel">
                        <Border Width="520" Margin="0,0,16,16">
                            <StackPanel Spacing="6">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                                <TextBlock Foreground="#52606D"
                                           Text="{Binding Description}"
                                           TextWrapping="Wrap" />

                                <TextBox IsVisible="{Binding IsText}"
                                         Text="{Binding PrimaryValue, Mode=TwoWay}"
                                         Watermark="{Binding PrimaryPlaceholder}" />

                                <ComboBox IsVisible="{Binding IsSelect}"
                                          ItemsSource="{Binding Options}"
                                          SelectedItem="{Binding SelectedOption, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="filters:FilterOption">
                                            <TextBlock Text="{Binding Label}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <Grid IsVisible="{Binding IsRange}" ColumnDefinitions="*,*" ColumnSpacing="12">
                                    <TextBox Grid.Column="0"
                                             Text="{Binding PrimaryValue, Mode=TwoWay}"
                                             Watermark="{Binding PrimaryPlaceholder}" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding SecondaryValue, Mode=TwoWay}"
                                             Watermark="{Binding SecondaryPlaceholder}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Command="{Binding #Root.ApplyCommand}" Content="Apply filters" />
                <Button Command="{Binding #Root.ClearCommand}" Content="Clear filters" />
            </StackPanel>
        </StackPanel>
    </Expander>
</UserControl>
