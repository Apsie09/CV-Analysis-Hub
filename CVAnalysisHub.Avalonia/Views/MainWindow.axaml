<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CVAnalysisHub.Avalonia.ViewModels"
        xmlns:views="using:CVAnalysisHub.Avalonia.Views"
        xmlns:objectLists="using:CVAnalysisHub.Application.Common.ObjectLists"
        mc:Ignorable="d"
        x:Class="CVAnalysisHub.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="CVAnalysisHub Desktop"
        Width="1520"
        Height="980"
        MinWidth="1200"
        MinHeight="820">
    <Grid RowDefinitions="Auto,Auto,*" Background="#F4F7FA">
        <Border Padding="24" Background="#0F172A">
            <StackPanel Spacing="8">
                <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Text="CVAnalysisHub Desktop" />
                <TextBlock Foreground="#D7E3F4"
                           Text="Avalonia client reusing the shared Application ViewModels for browsing, filtering, uploads, and analysis orchestration." />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="20,16,20,0" ColumnDefinitions="*,*" ColumnSpacing="16">
            <Border Padding="14" Background="#E8F6EE" CornerRadius="14" IsVisible="{Binding Notifications.HasStatusMessage}">
                <TextBlock Foreground="#1F5F3B" Text="{Binding Notifications.StatusMessage}" TextWrapping="Wrap" />
            </Border>

            <Border Grid.Column="1" Padding="14" Background="#FDECEC" CornerRadius="14" IsVisible="{Binding Notifications.HasErrorMessage}">
                <TextBlock Foreground="#9F2D2D" Text="{Binding Notifications.ErrorMessage}" TextWrapping="Wrap" />
            </Border>
        </Grid>

        <TabControl Grid.Row="2" Margin="20">
            <TabItem Header="Overview">
                <views:OverviewView />
            </TabItem>

            <TabItem Header="Videos">
                <views:VideosView />
            </TabItem>

            <TabItem Header="Analyses">
                <views:AnalysesView />
            </TabItem>
        </TabControl>
    </Grid>
</Window>
