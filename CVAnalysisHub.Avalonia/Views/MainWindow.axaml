<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CVAnalysisHub.Avalonia.ViewModels"
        xmlns:objectLists="using:CVAnalysisHub.Application.Common.ObjectLists"
        mc:Ignorable="d"
        x:Class="CVAnalysisHub.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="CVAnalysisHub Desktop"
        Width="1520"
        Height="980"
        MinWidth="1200"
        MinHeight="820">
    <Grid RowDefinitions="Auto,Auto,*" Background="#F4F7FA">
        <Border Padding="24" Background="#0F172A">
            <StackPanel Spacing="8">
                <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Text="CVAnalysisHub Desktop" />
                <TextBlock Foreground="#D7E3F4"
                           Text="Avalonia client reusing the shared Application ViewModels for browsing, filtering, uploads, and analysis orchestration." />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="20,16,20,0" ColumnDefinitions="*,*" ColumnSpacing="16">
            <Border Padding="14" Background="#E8F6EE" CornerRadius="14" IsVisible="{Binding HasStatusMessage}">
                <TextBlock Foreground="#1F5F3B" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
            </Border>

            <Border Grid.Column="1" Padding="14" Background="#FDECEC" CornerRadius="14" IsVisible="{Binding HasErrorMessage}">
                <TextBlock Foreground="#9F2D2D" Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
            </Border>
        </Grid>

        <TabControl Grid.Row="2" Margin="20">
            <TabItem Header="Overview">
                <ScrollViewer>
                    <StackPanel Spacing="16">
                        <Border Padding="20" Background="White" CornerRadius="18">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="Shared HomeViewModel" />
                                <TextBlock Foreground="#52606D"
                                           Text="These desktop metrics are loaded from the same shared summary ViewModel used by the web application." />
                                <Button HorizontalAlignment="Left"
                                        Command="{Binding RefreshOverviewCommand}"
                                        Content="Refresh overview" />
                            </StackPanel>
                        </Border>

                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="16">
                            <Border Grid.Column="0" Padding="18" Background="White" CornerRadius="16">
                                <StackPanel Spacing="6">
                                    <TextBlock Foreground="#52606D" Text="Videos" />
                                    <TextBlock FontSize="30" FontWeight="Bold" Text="{Binding Home.TotalVideos}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Padding="18" Background="White" CornerRadius="16">
                                <StackPanel Spacing="6">
                                    <TextBlock Foreground="#52606D" Text="Analyses" />
                                    <TextBlock FontSize="30" FontWeight="Bold" Text="{Binding Home.TotalAnalysisRuns}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Padding="18" Background="White" CornerRadius="16">
                                <StackPanel Spacing="6">
                                    <TextBlock Foreground="#52606D" Text="Queued" />
                                    <TextBlock FontSize="30" FontWeight="Bold" Text="{Binding Home.QueuedAnalysisRuns}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Padding="18" Background="White" CornerRadius="16">
                                <StackPanel Spacing="6">
                                    <TextBlock Foreground="#52606D" Text="Completed" />
                                    <TextBlock FontSize="30" FontWeight="Bold" Text="{Binding Home.CompletedCount}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Padding="18" Background="White" CornerRadius="16">
                            <StackPanel Spacing="6">
                                <TextBlock Foreground="#52606D" Text="Latest upload" />
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding Home.LatestVideoName}" />
                                <TextBlock Text="{Binding Home.LatestUploadUtc}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Videos">
                <ScrollViewer>
                    <StackPanel Spacing="16">
                        <Border Padding="18" Background="White" CornerRadius="16">
                            <Expander IsExpanded="False">
                                <Expander.Header>
                                    <StackPanel Spacing="4">
                                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Advanced filters" />
                                        <TextBlock Foreground="#52606D"/>
                                    </StackPanel>
                                </Expander.Header>

                                <StackPanel Margin="0,16,0,0" Spacing="14">
                                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="16" RowSpacing="12">
                                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding VideoNameFilter.Label}" />
                                            <TextBlock Foreground="#52606D" Text="{Binding VideoNameFilter.Description}" TextWrapping="Wrap" />
                                            <TextBox Text="{Binding VideoNameFilter.PrimaryValue, Mode=TwoWay}"
                                                     Watermark="{Binding VideoNameFilter.PrimaryPlaceholder}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding VideoStatusFilter.Label}" />
                                            <TextBlock Foreground="#52606D" Text="{Binding VideoStatusFilter.Description}" TextWrapping="Wrap" />
                                            <ComboBox ItemsSource="{Binding VideoStatusOptions}"
                                                      SelectedItem="{Binding SelectedVideoStatusOption, Mode=TwoWay}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Label}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding VideoDurationFilter.Label}" />
                                            <TextBlock Foreground="#52606D" Text="{Binding VideoDurationFilter.Description}" TextWrapping="Wrap" />
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding VideoDurationFilter.PrimaryValue, Mode=TwoWay}"
                                                         Watermark="{Binding VideoDurationFilter.PrimaryPlaceholder}" />
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding VideoDurationFilter.SecondaryValue, Mode=TwoWay}"
                                                         Watermark="{Binding VideoDurationFilter.SecondaryPlaceholder}" />
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding VideoUploadedFilter.Label}" />
                                            <TextBlock Foreground="#52606D" Text="{Binding VideoUploadedFilter.Description}" TextWrapping="Wrap" />
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding VideoUploadedFilter.PrimaryValue, Mode=TwoWay}"
                                                         Watermark="yyyy-MM-dd" />
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding VideoUploadedFilter.SecondaryValue, Mode=TwoWay}"
                                                         Watermark="yyyy-MM-dd" />
                                            </Grid>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Button Command="{Binding ApplyVideoFiltersCommand}" Content="Apply filters" />
                                        <Button Command="{Binding ClearVideoFiltersCommand}" Content="Clear filters" />
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                        </Border>

                        <Border Padding="18" Background="White" CornerRadius="16">
                            <StackPanel Spacing="12">
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="Upload Video" />
                                <TextBlock Foreground="#52606D"
                                           Text="Choose a local video file, send it through the shared CreateVideoViewModel, and refresh the desktop library automatically." />

                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                                    <Button Click="SelectUploadFile_OnClick" Content="Choose file" />
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding SelectedUploadFileName}" />
                                        <TextBlock Foreground="#52606D" Text="{Binding SelectedUploadFileSize}" />
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            Command="{Binding UploadSelectedVideoCommand}"
                                            IsEnabled="{Binding CanUploadSelectedVideo}"
                                            Content="Upload to library" />
                                </Grid>

                                <StackPanel Spacing="6">
                                    <TextBlock FontWeight="SemiBold" Text="Estimated duration in seconds" />
                                    <TextBox Text="{Binding CreateVideo.DurationSeconds, Mode=TwoWay}" Width="160" />
                                </StackPanel>

                                <ProgressBar Minimum="0"
                                             Maximum="100"
                                             Height="12"
                                             Value="{Binding CreateVideo.ProgressPercent}" />
                                <TextBlock Foreground="#52606D" Text="{Binding CreateVideo.ProgressMessage}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Padding="18" Background="White" CornerRadius="16">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                    <StackPanel Spacing="6">
                                        <TextBlock FontSize="22" FontWeight="SemiBold" Text="Video Library" />
                                        <TextBlock Foreground="#52606D"
                                                   Text="Browse uploaded videos, inspect the selected item, and start a new analysis from the same shared application data." />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                        <Button Command="{Binding ReloadVideosCommand}" Content="Refresh list" />
                                        <Button Command="{Binding ClearVideosCommand}" Content="Clear list" />
                                    </StackPanel>
                                </Grid>

                                <Expander IsExpanded="False">
                                    <Expander.Header>
                                        <TextBlock FontWeight="SemiBold" Text="Customize visible columns" />
                                    </Expander.Header>

                                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding Videos.Browser.AvailableColumns}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="objectLists:ObjectListColumnViewModel">
                                                <CheckBox Margin="0,0,12,8"
                                                          Content="{Binding Header}"
                                                          IsChecked="{Binding IsVisible, Mode=TwoWay}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>

                                <Grid ColumnDefinitions="2.4*,1*" ColumnSpacing="16">
                                    <Border Padding="12" Background="#FBFCFE" CornerRadius="12">
                                        <StackPanel Spacing="8">
                                            <ItemsControl ItemsSource="{Binding Videos.Browser.VisibleColumns}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="objectLists:ObjectListColumnViewModel">
                                                        <Border Width="180" Padding="8" Margin="0,0,8,0" Background="#E8EEF7" CornerRadius="10">
                                                            <TextBlock FontWeight="SemiBold" Text="{Binding Header}" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <ListBox ItemsSource="{Binding Videos.Browser.Rows}"
                                                     SelectedItem="{Binding Videos.Browser.SelectedRow, Mode=TwoWay}"
                                                     MinHeight="260">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <ItemsControl ItemsSource="{Binding Cells}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="objectLists:ObjectListCellViewModel">
                                                                    <Border Width="180" Padding="8" BorderBrush="#D8E1EB" BorderThickness="0,0,0,1">
                                                                        <TextBlock Text="{Binding Value}" TextWrapping="Wrap" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Padding="18" Background="#FBFCFE" CornerRadius="12">
                                        <StackPanel Spacing="10">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="Selected Video(Preview)" />
                                                <Button Grid.Column="1"
                                                        Command="{Binding OpenSelectedVideoCommand}"
                                                        IsEnabled="{Binding HasSelectedVideoSource}"
                                                        Content="Open video" />
                                            </Grid>
                                            <TextBlock Foreground="#52606D"/>
                                            <Border Height="220" Background="#0F172A" CornerRadius="12" ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding SelectedVideoPreview}"
                                                           Stretch="UniformToFill"
                                                           IsVisible="{Binding HasSelectedVideoPreview}" />
                                                    <StackPanel HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Spacing="6"
                                                                IsVisible="{Binding MissingSelectedVideoPreview}">
                                                        <TextBlock HorizontalAlignment="Center"
                                                                   FontSize="18"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="White"
                                                                   Text="Preview unavailable" />
                                                        <TextBlock HorizontalAlignment="Center"
                                                                   Foreground="#CBD5E1"
                                                                   Text="Open the video to inspect it in the system player." />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <TextBlock FontWeight="SemiBold" Text="Original file" />
                                            <TextBlock Text="{Binding Videos.Browser.SelectedItem.OriginalFileName, FallbackValue=No selection}" />
                                            <TextBlock FontWeight="SemiBold" Text="Stored file" />
                                            <TextBlock Text="{Binding Videos.Browser.SelectedItem.FileName, FallbackValue=-}" />
                                            <TextBlock FontWeight="SemiBold" Text="Duration" />
                                            <TextBlock Text="{Binding Videos.Browser.SelectedItem.Duration, FallbackValue=-}" />
                                            <TextBlock FontWeight="SemiBold" Text="Video status" />
                                            <TextBlock Text="{Binding Videos.Browser.SelectedItem.Status, FallbackValue=-}" />
                                            <TextBlock FontWeight="SemiBold" Text="Content type" />
                                            <TextBlock Text="{Binding Videos.Browser.SelectedItem.ContentType, FallbackValue=-}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Analyses">
                <ScrollViewer>
                    <StackPanel Spacing="16">
                        <Border Padding="18" Background="White" CornerRadius="16">
                            <Expander IsExpanded="False">
                                <Expander.Header>
                                    <StackPanel Spacing="4">
                                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Advanced filters" />
                                        <TextBlock Foreground="#52606D"/>
                                    </StackPanel>
                                </Expander.Header>

                                <StackPanel Margin="0,16,0,0" Spacing="14">
                                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="16" RowSpacing="12">
                                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding AnalysisVideoNameFilter.Label}" />
                                            <TextBlock Foreground="#52606D" Text="{Binding AnalysisVideoNameFilter.Description}" TextWrapping="Wrap" />
                                            <TextBox Text="{Binding AnalysisVideoNameFilter.PrimaryValue, Mode=TwoWay}"
                                                     Watermark="{Binding AnalysisVideoNameFilter.PrimaryPlaceholder}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding AnalysisModelNameFilter.Label}" />
                                            <TextBlock Foreground="#52606D" Text="{Binding AnalysisModelNameFilter.Description}" TextWrapping="Wrap" />
                                            <TextBox Text="{Binding AnalysisModelNameFilter.PrimaryValue, Mode=TwoWay}"
                                                     Watermark="{Binding AnalysisModelNameFilter.PrimaryPlaceholder}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding AnalysisStatusFilter.Label}" />
                                            <TextBlock Foreground="#52606D" Text="{Binding AnalysisStatusFilter.Description}" TextWrapping="Wrap" />
                                            <ComboBox ItemsSource="{Binding AnalysisStatusOptions}"
                                                      SelectedItem="{Binding SelectedAnalysisStatusOption, Mode=TwoWay}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Label}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding AnalysisDetectedObjectCountFilter.Label}" />
                                            <TextBlock Foreground="#52606D" Text="{Binding AnalysisDetectedObjectCountFilter.Description}" TextWrapping="Wrap" />
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding AnalysisDetectedObjectCountFilter.PrimaryValue, Mode=TwoWay}"
                                                         Watermark="{Binding AnalysisDetectedObjectCountFilter.PrimaryPlaceholder}" />
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding AnalysisDetectedObjectCountFilter.SecondaryValue, Mode=TwoWay}"
                                                         Watermark="{Binding AnalysisDetectedObjectCountFilter.SecondaryPlaceholder}" />
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="0" Spacing="6">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding AnalysisCreatedFilter.Label}" />
                                            <TextBlock Foreground="#52606D" Text="{Binding AnalysisCreatedFilter.Description}" TextWrapping="Wrap" />
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding AnalysisCreatedFilter.PrimaryValue, Mode=TwoWay}"
                                                         Watermark="yyyy-MM-dd" />
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding AnalysisCreatedFilter.SecondaryValue, Mode=TwoWay}"
                                                         Watermark="yyyy-MM-dd" />
                                            </Grid>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Button Command="{Binding ApplyAnalysisFiltersCommand}" Content="Apply filters" />
                                        <Button Command="{Binding ClearAnalysisFiltersCommand}" Content="Clear filters" />
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                        </Border>

                        <Border Padding="18" Background="White" CornerRadius="16">
                            <StackPanel Spacing="12">
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="Run New Analysis" />
                                <TextBlock Foreground="#52606D"/>

                                <StackPanel Spacing="6">
                                    <TextBlock FontWeight="SemiBold" Text="Source video" />
                                    <ComboBox ItemsSource="{Binding CreateAnalysis.AvailableVideos}"
                                              SelectedItem="{Binding SelectedCreateAnalysisVideo, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding OriginalFileName}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock FontWeight="SemiBold" Text="Model name" />
                                    <TextBox Text="{Binding CreateAnalysis.ModelName, Mode=TwoWay}" Width="220" />
                                </StackPanel>

                                <Button HorizontalAlignment="Left"
                                        Command="{Binding CreateAnalysisCommand}"
                                        IsEnabled="{Binding CanCreateAnalysis}"
                                        Content="Queue analysis" />
                            </StackPanel>
                        </Border>

                        <Border Padding="18" Background="White" CornerRadius="16">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                    <StackPanel Spacing="6">
                                        <TextBlock FontSize="22" FontWeight="SemiBold" Text="Analysis History" />
                                        <TextBlock Foreground="#52606D"
                                                   Text="Review queued, running, completed, or failed analyses and inspect the selected run in detail." />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                        <Button Command="{Binding ReloadAnalysisRunsCommand}" Content="Refresh list" />
                                        <Button Command="{Binding ClearAnalysisRunsCommand}" Content="Clear list" />
                                    </StackPanel>
                                </Grid>

                                <Expander IsExpanded="False">
                                    <Expander.Header>
                                        <TextBlock FontWeight="SemiBold" Text="Customize visible columns" />
                                    </Expander.Header>

                                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding AnalysisRuns.Browser.AvailableColumns}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="objectLists:ObjectListColumnViewModel">
                                                <CheckBox Margin="0,0,12,8"
                                                          Content="{Binding Header}"
                                                          IsChecked="{Binding IsVisible, Mode=TwoWay}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>

                                <Grid ColumnDefinitions="2.2*,1.2*" ColumnSpacing="16">
                                    <Border Padding="12" Background="#FBFCFE" CornerRadius="12">
                                        <StackPanel Spacing="8">
                                            <ItemsControl ItemsSource="{Binding AnalysisRuns.Browser.VisibleColumns}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="objectLists:ObjectListColumnViewModel">
                                                        <Border Width="180" Padding="8" Margin="0,0,8,0" Background="#E8EEF7" CornerRadius="10">
                                                            <TextBlock FontWeight="SemiBold" Text="{Binding Header}" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <ListBox ItemsSource="{Binding AnalysisRuns.Browser.Rows}"
                                                     SelectedItem="{Binding AnalysisRuns.Browser.SelectedRow, Mode=TwoWay}"
                                                     MinHeight="260">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <ItemsControl ItemsSource="{Binding Cells}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="objectLists:ObjectListCellViewModel">
                                                                    <Border Width="180" Padding="8" BorderBrush="#D8E1EB" BorderThickness="0,0,0,1">
                                                                        <TextBlock Text="{Binding Value}" TextWrapping="Wrap" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Padding="18" Background="#FBFCFE" CornerRadius="12">
                                        <StackPanel Spacing="10">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="Analysis Details" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                    <Button Command="{Binding OpenSelectedSourceVideoCommand}"
                                                            IsEnabled="{Binding HasSelectedAnalysisSourceVideo}"
                                                            Content="Open source" />
                                                    <Button Command="{Binding OpenSelectedOutputVideoCommand}"
                                                            IsEnabled="{Binding HasSelectedAnalysisOutputVideo}"
                                                            Content="Open output" />
                                                    <Button Command="{Binding RefreshSelectedAnalysisDetailsCommand}"
                                                            Content="Refresh details" />
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock Foreground="#52606D"
                                                       Text="The details pane is fed by the shared AnalysisRunDetailsViewModel and updates when the selected analysis row changes." />
                                            <TextBlock FontWeight="SemiBold" Text="Video" />
                                            <TextBlock Text="{Binding AnalysisDetails.AnalysisRun.VideoName, FallbackValue=Select an analysis to inspect details}" />
                                            <TextBlock FontWeight="SemiBold" Text="Model" />
                                            <TextBlock Text="{Binding AnalysisDetails.AnalysisRun.ModelName, FallbackValue=-}" />
                                            <TextBlock FontWeight="SemiBold" Text="Analysis status" />
                                            <TextBlock Text="{Binding AnalysisDetails.AnalysisRun.Status, FallbackValue=-}" />
                                            <TextBlock FontWeight="SemiBold" Text="Progress headline" />
                                            <TextBlock Text="{Binding AnalysisDetails.AnalysisRun.ProgressHeadline, FallbackValue=-}" TextWrapping="Wrap" />
                                            <TextBlock FontWeight="SemiBold" Text="Progress description" />
                                            <TextBlock Text="{Binding AnalysisDetails.AnalysisRun.ProgressDescription, FallbackValue=-}" TextWrapping="Wrap" />
                                            <TextBlock FontWeight="SemiBold" Text="Objects detected" />
                                            <TextBlock Text="{Binding AnalysisDetails.AnalysisRun.DetectedObjectCount, FallbackValue=-}" />
                                            <TextBlock FontWeight="SemiBold" Text="Failure reason" />
                                            <TextBlock Text="{Binding AnalysisDetails.AnalysisRun.FailureReason, FallbackValue=-}" TextWrapping="Wrap" />
                                            <TextBlock FontWeight="SemiBold" Text="Last updated" />
                                            <TextBlock Text="{Binding AnalysisDetails.LastUpdatedAtUtc, FallbackValue=-}" />

                                            <ProgressBar Minimum="0"
                                                         Maximum="100"
                                                         Height="12"
                                                         Value="{Binding AnalysisDetails.AnalysisRun.ProgressPercent}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Padding="18" Background="White" CornerRadius="16">
                            <StackPanel Spacing="12">
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="Detected Objects" />
                                <TextBlock Foreground="#52606D"
                                           Text="A quick label summary from the persisted detections for the selected run." />

                                <ItemsControl ItemsSource="{Binding SelectedAnalysisDetectionSummary}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,6" Margin="0,0,10,10" Background="#E8EEF7" CornerRadius="999">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                            <Border Padding="18" Background="White" CornerRadius="16">
                                <StackPanel Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock FontSize="22" FontWeight="SemiBold" Text="Source Video" />
                                            <TextBlock Foreground="#52606D"
                                                       Text="Preview the uploaded source media stored by the platform." />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Command="{Binding OpenSelectedSourceVideoCommand}"
                                                IsEnabled="{Binding HasSelectedAnalysisSourceVideo}"
                                                Content="Open source" />
                                    </Grid>

                                    <Border Height="340" Background="#0F172A" CornerRadius="12" ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding SelectedAnalysisSourcePreview}"
                                                   Stretch="UniformToFill"
                                                   IsVisible="{Binding HasSelectedAnalysisSourcePreview}" />
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Spacing="6"
                                                        IsVisible="{Binding MissingSelectedAnalysisSourcePreview}">
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"
                                                           Text="Source preview unavailable" />
                                                <TextBlock HorizontalAlignment="Center"
                                                           Foreground="#CBD5E1"
                                                           Text="Use Open source to inspect the original video." />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Padding="18" Background="White" CornerRadius="16">
                                <StackPanel Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock FontSize="22" FontWeight="SemiBold" Text="Output Video" />
                                            <TextBlock Foreground="#52606D"
                                                       Text="Preview the annotated output so the detections are visible at a glance." />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Command="{Binding OpenSelectedOutputVideoCommand}"
                                                IsEnabled="{Binding HasSelectedAnalysisOutputVideo}"
                                                Content="Open output" />
                                    </Grid>

                                    <Border Height="340" Background="#0F172A" CornerRadius="12" ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding SelectedAnalysisOutputPreview}"
                                                   Stretch="UniformToFill"
                                                   IsVisible="{Binding HasSelectedAnalysisOutputPreview}" />
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Spacing="6"
                                                        IsVisible="{Binding MissingSelectedAnalysisOutputPreview}">
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"
                                                           Text="Output preview unavailable" />
                                                <TextBlock HorizontalAlignment="Center"
                                                           Foreground="#CBD5E1"
                                                           Text="This run may still be processing or has no generated output yet." />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Padding="18" Background="White" CornerRadius="16">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="Detection Results" />
                                <TextBlock Foreground="#52606D"
                                           Text="Persisted detections from the selected analysis run are surfaced here from the shared details DTO." />

                                <Border Padding="10" Background="#EEF3F8" CornerRadius="10">
                                    <Grid ColumnDefinitions="70,120,90,80,80,80,80" ColumnSpacing="12">
                                        <TextBlock Grid.Column="0" FontWeight="SemiBold" Text="Frame" />
                                        <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Label" />
                                        <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Confidence" />
                                        <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="X" />
                                        <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="Y" />
                                        <TextBlock Grid.Column="5" FontWeight="SemiBold" Text="Width" />
                                        <TextBlock Grid.Column="6" FontWeight="SemiBold" Text="Height" />
                                    </Grid>
                                </Border>

                                <ItemsControl ItemsSource="{Binding AnalysisDetails.AnalysisRun.DetectionResults}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10" Margin="0,0,0,8" Background="#FBFCFE" CornerRadius="10">
                                                <Grid ColumnDefinitions="70,120,90,80,80,80,80" ColumnSpacing="12">
                                                    <TextBlock Grid.Column="0" Text="{Binding FrameNumber}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Label}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Confidence}" />
                                                    <TextBlock Grid.Column="3" Text="{Binding X}" />
                                                    <TextBlock Grid.Column="4" Text="{Binding Y}" />
                                                    <TextBlock Grid.Column="5" Text="{Binding Width}" />
                                                    <TextBlock Grid.Column="6" Text="{Binding Height}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
