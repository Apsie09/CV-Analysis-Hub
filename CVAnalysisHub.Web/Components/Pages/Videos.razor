@page "/videos"
@using CVAnalysisHub.Application.Videos
@inject VideoListViewModel ViewModel

<PageTitle>Videos</PageTitle>

<div class="page-header">
    <div>
        <h1>Videos</h1>
        <p class="section-lead">Upload source videos, keep them organized, and launch analyses from the same library view.</p>
    </div>

    <a class="btn btn-primary" href="/videos/create">Upload video</a>
</div>

@if (ViewModel.IsLoading)
{
    <p>Loading videos...</p>
}
else
{
    <SearchFilterPanel
        Fields="ViewModel.Filters.Fields"
        Title="Reusable Video Search Filters"
        Description="These controls are generated from shared filter metadata, and the entered values build the database query for the video table."
        OnApply="ApplyFiltersAsync"
        OnClear="ClearFiltersAsync" />

    <section class="section-card list-controls-card">
        <div class="page-header">
            <div>
                <h2>Reusable Video Browser</h2>
                <p class="section-lead">
                    Choose the columns to display, select a row to inspect the full object, clear the current list, and reload it again.
                </p>
            </div>
            <div class="button-row">
                <button class="btn btn-outline-secondary" type="button" @onclick="ReloadAsync">Refresh list</button>
                <button class="btn btn-outline-secondary" type="button" @onclick="ClearDisplay">Clear list</button>
            </div>
        </div>

        <div class="column-toggle-row">
            @foreach (var column in ViewModel.Browser.AvailableColumns)
            {
                <label class="column-toggle">
                    <input
                        type="checkbox"
                        checked="@column.IsVisible"
                        @onchange="args => SetColumnVisibility(column.Key, args.Value)" />
                    <span>@column.Header</span>
                </label>
            }
        </div>
    </section>

    <section class="section-card">
        @if (!ViewModel.Browser.HasItems)
        {
            <p class="section-lead">
                @(ViewModel.HasActiveFilters
                    ? "No videos matched the current filter set. Clear the filters or widen the search."
                    : "The current visualization is empty. Reload the video list to bind a fresh set of objects.")
            </p>
        }
        else
        {
            <ObjectListTable TItem="VideoDto" ViewModel="ViewModel.Browser" OnRowSelected="HandleSelectedRow">
                <RowActions Context="video">
                    <div class="button-row">
                        <a class="btn btn-sm btn-outline-secondary" href="@($"/analyses/create?videoId={video.Id}")">Analyze</a>
                        @if (!string.IsNullOrWhiteSpace(video.SourceVideoUrl))
                        {
                            <a class="btn btn-sm btn-outline-secondary" href="@video.SourceVideoUrl" target="_blank">Open source</a>
                        }
                    </div>
                </RowActions>
            </ObjectListTable>
        }
    </section>

    @if (ViewModel.SelectedVideo is not null)
    {
        <section class="section-card selection-summary-card">
            <div class="page-header">
                <div>
                    <h2>Selected Video</h2>
                    <p class="section-lead">Selection returns the full `VideoDto`, even when some columns are hidden from the list.</p>
                </div>
                <span class="status-badge is-neutral">@ViewModel.SelectedVideo.Status</span>
            </div>

            <div class="details-grid">
                <div>
                    <span class="metric-label">Original file</span>
                    <strong>@ViewModel.SelectedVideo.OriginalFileName</strong>
                </div>
                <div>
                    <span class="metric-label">Stored file</span>
                    <strong>@ViewModel.SelectedVideo.FileName</strong>
                </div>
                <div>
                    <span class="metric-label">Duration</span>
                    <strong>@ViewModel.SelectedVideo.Duration</strong>
                </div>
                <div>
                    <span class="metric-label">Uploaded</span>
                    <strong>@ViewModel.SelectedVideo.UploadedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</strong>
                </div>
                <div>
                    <span class="metric-label">Content type</span>
                    <strong>@(ViewModel.SelectedVideo.ContentType ?? "-")</strong>
                </div>
                <div>
                    <span class="metric-label">File size</span>
                    <strong>@FormatBytes(ViewModel.SelectedVideo.FileSizeBytes)</strong>
                </div>
            </div>
        </section>
    }
}

@code {
    protected override async Task OnInitializedAsync()
    {
        await ViewModel.LoadAsync();
    }

    private Task ReloadAsync()
    {
        return ViewModel.LoadAsync();
    }

    private Task ApplyFiltersAsync()
    {
        return ViewModel.ApplyFiltersAsync();
    }

    private Task ClearFiltersAsync()
    {
        return ViewModel.ClearFiltersAsync();
    }

    private void ClearDisplay()
    {
        ViewModel.ClearDisplay();
    }

    private void SetColumnVisibility(string columnKey, object? value)
    {
        ViewModel.SetColumnVisibility(columnKey, value as bool? ?? false);
    }

    private Task HandleSelectedRow(ObjectListRowViewModel<VideoDto> row)
    {
        ViewModel.SelectRow(row);
        return Task.CompletedTask;
    }

    private static string FormatBytes(long? sizeBytes)
    {
        if (sizeBytes is null)
        {
            return "-";
        }

        string[] suffixes = ["B", "KB", "MB", "GB"];
        var size = (double)sizeBytes.Value;
        var suffixIndex = 0;

        while (size >= 1024 && suffixIndex < suffixes.Length - 1)
        {
            size /= 1024;
            suffixIndex++;
        }

        return $"{size:0.##} {suffixes[suffixIndex]}";
    }
}
