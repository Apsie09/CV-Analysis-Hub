@startuml
left to right direction
skinparam componentStyle rectangle
skinparam packageStyle rectangle

package "View" {
  component "Blazor pages and components\nCVAnalysisHub.Web" as view_web
  component "Avalonia XAML views\nCVAnalysisHub.Avalonia/Views" as view_avalonia
}

package "ViewModel" {
  package "Shared Application ViewModels" {
    component "HomeViewModel" as vm_home
    component "VideoListViewModel" as vm_videos
    component "CreateVideoViewModel" as vm_create_video
    component "AnalysisRunListViewModel" as vm_analysis_list
    component "CreateAnalysisRunViewModel" as vm_create_analysis
    component "AnalysisRunDetailsViewModel" as vm_analysis_details
  }

  package "Avalonia desktop adapters" {
    component "MainWindowViewModel\n(shell coordinator)" as vm_shell
    component "VideoWorkspaceViewModel" as vm_video_workspace
    component "AnalysisWorkspaceViewModel" as vm_analysis_workspace
    component "DesktopUploadViewModel" as vm_upload
    component "MediaPreviewViewModel" as vm_preview
    component "DesktopNotificationViewModel" as vm_notifications
    component "DesktopMediaService\n(local media adapter)" as desktop_media
  }
}

package "Model" {
  component "Domain entities\nVideo, AnalysisRun, DetectionResult" as model_domain
  component "Application DTOs and requests" as model_dtos
  component "Infrastructure services\nEF Core, MediaStorage,\nVideoProcessing, Inference" as model_services
  database "SQLite / PostgreSQL" as model_db
}

view_web --> vm_home
view_web --> vm_videos
view_web --> vm_create_video
view_web --> vm_analysis_list
view_web --> vm_create_analysis
view_web --> vm_analysis_details

view_avalonia --> vm_shell
vm_shell --> vm_home
vm_shell --> vm_video_workspace
vm_shell --> vm_analysis_workspace
vm_shell --> vm_notifications
vm_video_workspace --> vm_videos
vm_video_workspace --> vm_create_video
vm_video_workspace --> vm_upload
vm_video_workspace --> vm_preview
vm_video_workspace --> desktop_media
vm_analysis_workspace --> vm_analysis_list
vm_analysis_workspace --> vm_create_analysis
vm_analysis_workspace --> vm_analysis_details
vm_analysis_workspace --> vm_preview
vm_analysis_workspace --> desktop_media

vm_home --> model_dtos
vm_videos --> model_dtos
vm_create_video --> model_dtos
vm_analysis_list --> model_dtos
vm_create_analysis --> model_dtos
vm_analysis_details --> model_dtos

model_dtos --> model_services
model_services --> model_domain
model_services --> model_db

note bottom of model_domain
Model в този проект не е една папка.
Той е реализиран чрез domain entities,
DTO-та, service contracts и infrastructure.
end note

@enduml
